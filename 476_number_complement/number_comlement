#include <iostream>

using namespace std;

class Solution {
public:
    int findComplement(int num) {
        int m = num;
        int mask = 0;

        while (m != 0) {
            mask = (mask << 1) | 1;
            m = m >> 1;
        }

        int ans = (~num) & mask;
        return ans;
    }
};

int main() {
    Solution sol;

    int num;

    cout << "Enter a positive integer: ";
    cin >> num;

    cout << "Complement: " << sol.findComplement(num) << endl;

    return 0;
}